{
  "name": "pi-web-file-browser",
  "version": "0.3.6",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:frontend && bun run build:backend",
    "typecheck": "bun x tsc --noEmit",
    "check": "bun run typecheck && bun run test && bun run build",
    "build:frontend": "bun build src/index.ts --outfile index.js --target browser --format esm --sourcemap=none --minify",
    "build:backend": "bun build backend.ts --outfile backend.js --target node --format esm --sourcemap=none",
    "test": "bun test"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@fsegurai/codemirror-theme-material-dark": "^6.2.5"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0",
    "@types/bun": "^1.3.3"
  }
}
